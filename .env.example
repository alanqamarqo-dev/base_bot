# ============================================================
# Base Launch Detector - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Base RPC Configuration (REQUIRED) ─────────────────────────
# WebSocket for live event streaming (recommended)
BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# HTTP for fallback polling
BASE_RPC_HTTP=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# Fallback RPC endpoints
BASE_RPC_WS_FALLBACK=wss://base-rpc.publicnode.com
BASE_RPC_HTTP_FALLBACK=https://mainnet.base.org

# ── Monitor Settings ──────────────────────────────────────────
# Enable/disable the real-time monitor
MONITOR_ENABLED=true
# Which DEXs to monitor
MONITOR_AERODROME=true
MONITOR_UNISWAP_V3=true
# Minimum liquidity in USD to trigger alerts
MIN_LIQUIDITY_ALERT_USD=500
# Seconds to wait before momentum analysis (default: 300 = 5min)
MOMENTUM_CHECK_AFTER_SECONDS=300
# Whale detection threshold (percentage of supply/volume)
WHALE_THRESHOLD_PERCENT=5
WHALE_EXIT_THRESHOLD_PERCENT=30
# Reconnection settings
RECONNECTION_DELAY=3.0
MAX_RECONNECTION_ATTEMPTS=10

# ── API Server ────────────────────────────────────────────────
# Enable/disable the API server
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000

# ── Telegram Configuration (REQUIRED for alerts) ───────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_here

# ── API Keys for Analyzers (OPTIONAL but recommended) ─────────
# Basescan API key for holder analysis (free at basescan.org)
BASESCAN_API_KEY=your_basescan_api_key_here
# GitHub token for repository analysis
GITHUB_TOKEN=your_github_token_here

# ── Database ───────────────────────────────────────────────────
DB_PATH=base_bot.db

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
