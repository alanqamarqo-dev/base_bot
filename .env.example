# ============================================================
# Base Chain Token Scanner Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Telegram Configuration (REQUIRED) ──────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Channel ID (e.g., @your_channel or -100xxxxx for private)
TELEGRAM_CHANNEL_ID=@your_channel_here

# ── API Keys (OPTIONAL but recommended) ────────────────────────
# Basescan API key for holder analysis (free at basescan.org)
BASESCAN_API_KEY=your_basescan_api_key_here
# GitHub token for repository analysis (free at github.com/settings/tokens)
GITHUB_TOKEN=your_github_token_here

# ── Database ───────────────────────────────────────────────────
DB_PATH=base_bot.db

# ── Scan Settings ──────────────────────────────────────────────
# How many tokens to scan per run
MAX_TOKENS_PER_SCAN=30
# Minimum liquidity in USD to consider a token
MIN_LIQUIDITY_USD=1000
# Whether to generate chart images (set to false for text-only)
ENABLE_CHARTS=true

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR